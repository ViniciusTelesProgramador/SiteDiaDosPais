# ============================================================
# Recado Surpresa — variáveis de ambiente
# Copie para .env.local (dev) e configure na Vercel (produção).
# Sem credenciais, o app roda em MODO DE SIMULAÇÃO local (dev).
# ============================================================

# --- Supabase (público — usado pelo client apenas para o check de configuração)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Supabase (PRIVADO — service role, só rotas de servidor; NUNCA exponha)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# E-mail de suporte exibido no site (opcional)
NEXT_PUBLIC_SUPORTE_EMAIL=suporte@seudominio.com.br

# --- Mercado Pago (PRIVADO)
MERCADO_PAGO_ACCESS_TOKEN=your-mercadopago-access-token
# Secret de webhook (painel MP > Webhooks > assinatura secreta).
# OBRIGATÓRIO em produção: sem ele, todo webhook é rejeitado (fail closed).
MERCADO_PAGO_WEBHOOK_SECRET=your-mercadopago-webhook-secret

# --- Resend (PRIVADO) — usar domínio verificado (SPF/DKIM) em produção
RESEND_API_KEY=re_your_resend_api_key
MAIL_FROM=Recado Surpresa <contato@seudominio.com.br>

# --- Cron (PRIVADO) — protege /api/cron/*; a Vercel envia como Bearer token
CRON_SECRET=uma-string-aleatoria-longa
